REDIS_URL=redis://redis:6379
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-2.5-flash
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX=fifa-soc-incidents
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# 1 = enable outbound calls: IP geolocation (ipapi.co), public IP blocklists
# (Spamhaus DROP / Tor exit list / FireHOL, all free/no-key), and real WHOIS
# lookups. 0 = fully offline heuristics (deterministic demo mode).
ENABLE_LIVE_INTEL=0
BLOCKLIST_REFRESH_HOURS=6

VITE_API=http://localhost:8080
